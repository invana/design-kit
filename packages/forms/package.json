{
  "name": "@invana/forms",
  "version": "0.0.0",
  "description": "Invana Design System - Composable form building blocks (FormField + ObjectField + leaf inputs)",
  "homepage": "https://github.com/invana/design-kit#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "design-system",
    "react",
    "tailwindcss",
    "forms",
    "form-generator",
    "schema",
    "invana/forms"
  ],
  "bugs": {
    "url": "https://github.com/invana/design-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/invana/design-kit.git",
    "directory": "packages/forms"
  },
  "license": "MIT",
  "author": "Ravi Raja Merugu",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "pnpm run build",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@invana/styling": "workspace:*",
    "@invana/ui": "workspace:*",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-hook-form": "^7"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.562.0"
  },
  "devDependencies": {
    "@invana/styling": "workspace:*",
    "@invana/ui": "workspace:*",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.69.0",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3"
  }
}
